{
  "manifest_version": 3,
  "name": "Burned Cookies",
  "version": "1.0.0",
  "description": "Deletes non-whitelisted cookies for a site when its tabs are closed. Includes exact and wildcard whitelist import/export.",
  "permissions": [
    "cookies",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Burned Cookies",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
